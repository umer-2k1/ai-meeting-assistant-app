# ===========================================
# AI Meeting Copilot - Environment Variables
# ===========================================

# -----------------
# Database
# -----------------
DATABASE_URL=postgresql://user:password@localhost:5432/ai_meeting_copilot

# -----------------
# Authentication
# -----------------
# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Session secret for JWT/cookies
SESSION_SECRET=

# -----------------
# AI Services
# -----------------
# Groq API for LLM inference
GROQ_API_KEY=

# Google Gemini API for embeddings
GOOGLE_GEMINI_API_KEY=

# -----------------
# Speech-to-Text
# -----------------
# Deepgram API for real-time transcription
DEEPGRAM_API_KEY=

# -----------------
# Vector Database
# -----------------
# Qdrant vector store (local or cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -----------------
# File Storage
# -----------------
# Cloudinary for audio/media storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------
# Integrations
# -----------------
# Slack Bot Token
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Email Service (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=

# -----------------
# Application
# -----------------
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# -----------------
# Optional: Web Enrichment
# -----------------
# For attendee intelligence (LinkedIn, etc.)
SERPER_API_KEY=
