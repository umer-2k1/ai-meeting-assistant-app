# Backend Environment Variables
# Copy this to .env and fill in your actual values

DATABASE_URL=postgresql://user:password@localhost:5432/ai_meeting_copilot

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# JWT/Session
SESSION_SECRET=
JWT_SECRET=

# AI Services
GROQ_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Speech-to-Text
DEEPGRAM_API_KEY=

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# File Storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Integrations
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SENDGRID_API_KEY=
FROM_EMAIL=

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Optional
SERPER_API_KEY=
